{
  "manifest_version": 3,
  "name": "BrowseClaw",
  "version": "1.0.0",
  "description": "Control any webpage through OpenClaw AI — chat, automate, extract, and interact with pages using natural language.",

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "contextMenus"
  ],

  "commands": {
    "focus-input": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "Command+Shift+B"
      },
      "description": "Focus BrowseClaw input"
    }
  },

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Open BrowseClaw",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_page": "settings.html"
}
